SOLANA_NETWORK=devnet
SOLANA_RPC=https://api.devnet.solana.com

# Devnet-only signer used by scripts/reproduce-devnet.js --live.
# Use a disposable funded devnet keypair only. Accepted formats:
# - base58 encoded secret key
# - JSON array exported by solana-keygen
SERVER_PRIVATE_KEY=

# Optional bettor/recipient signers. If empty, the live script generates and funds them.
BETTOR_PRIVATE_KEY=
RECIPIENT_PRIVATE_KEY=

# Private settlement asset. For SOL-like UX this example uses wSOL.
PVP_BETTING_PRIVATE_MINT=So11111111111111111111111111111111111111112

# MagicBlock Private Payments / TEE endpoints.
MAGICBLOCK_PAYMENTS_API_URL=https://payments.magicblock.app
MAGICBLOCK_PRIVATE_TEE_URL=https://devnet-tee.magicblock.app
PVP_BETTING_MAGICBLOCK_VALIDATOR_ID=MTEWGuqxUpYZGFJQcp8tLN7x5v9BSeoFHYWQQ3n3xzo

# Optional simulation knobs.
DEMO_INTAKE_SOL=0.01
DEMO_PAYOUT_SOL=0.005
DEMO_BETTOR_WRAP_SOL=0.05
DEMO_RECIPIENT_INIT_SOL=0.001
ESTIMATED_MAGICBLOCK_COST_SOL=0
